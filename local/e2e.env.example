# Copy to local/e2e.env, fill values, then run:
#   set -a
#   source local/e2e.env
#   set +a
#   scripts/run-tests.sh live

AAI_E2E_CONFIG=./local/e2e.config.toml

# Token secrets referenced by local/e2e.config.toml.
GITHUB_TOKEN=
JIRA_API_TOKEN=
CONFLUENCE_API_TOKEN=
BITBUCKET_API_TOKEN=
GOOGLE_GMAIL_ACCESS_TOKEN=
GOOGLE_CALENDAR_ACCESS_TOKEN=
PIPEDRIVE_API_TOKEN=
# Zoho app passwords are used for SMTP/IMAP and CalDAV transports.
ZOHO_MAIL_APP_PASSWORD=
ZOHO_CALENDAR_APP_PASSWORD=

# Profile selectors used by tests/e2e_live.rs.
AAI_E2E_GITHUB_PROFILE=github-work
AAI_E2E_JIRA_PROFILE=jira-work
AAI_E2E_CONFLUENCE_PROFILE=confluence-work
AAI_E2E_BITBUCKET_PROFILE=bitbucket-work
AAI_E2E_GMAIL_PROFILE=gmail-work
AAI_E2E_GOOGLE_CALENDAR_PROFILE=google-calendar-work
AAI_E2E_ZOHO_MAIL_PROFILE=zoho-mail-work
AAI_E2E_ZOHO_CALENDAR_PROFILE=zoho-calendar-work
AAI_E2E_PIPEDRIVE_PROFILE=pipedrive-work

# Disposable resources used by live tests.
AAI_E2E_JIRA_PROJECT=ENG
AAI_E2E_JIRA_BOARD=
AAI_E2E_JIRA_ACCOUNT_ID=
AAI_E2E_CONFLUENCE_SPACE_ID=
AAI_E2E_BITBUCKET_REPO=
AAI_E2E_EMAIL_TO=

# Optional PR tests. Leave empty/unset to skip PR creation branches.
AAI_E2E_GITHUB_PR_HEAD=
AAI_E2E_GITHUB_PR_BASE=main
AAI_E2E_BITBUCKET_PR_SOURCE=
AAI_E2E_BITBUCKET_PR_DESTINATION=main
# Optional read-only Bitbucket source/review tests.
AAI_E2E_BITBUCKET_BRANCH=
AAI_E2E_BITBUCKET_COMMIT_SHA=
AAI_E2E_BITBUCKET_SOURCE_PATH=README.md
